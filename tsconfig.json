{
  "compilerOptions": {
    // General
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "types": ["vite/client"],

    // Modules
    "esModuleInterop": true,
    "isolatedModules": true,

    // Type Checking & Safety
    "skipLibCheck": true,
    "strict": true
  }
}
